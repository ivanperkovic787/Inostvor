<Window
    x:Class="Inostvor.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Inostvor.ViewModels"
    xmlns:skia="using:SkiaSharp.Views.Windows">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="190" MinHeight="90" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- ======== Toolbar ======== -->
    <StackPanel
        Grid.Row="0" Orientation="Horizontal" Spacing="4"
        Padding="8,6,8,6"
        Background="{ThemeResource LayerFillColorDefaultBrush}">
      <Button Command="{x:Bind ViewModel.OpenDxfCommand}">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE8E5;" FontSize="14" />
          <TextBlock Text="Otvori DXF" />
        </StackPanel>
      </Button>
      <Button Command="{x:Bind ViewModel.ExportGCodeCommand}" ToolTipService.ToolTip="Izvezi G-kod za aktivni stroj">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE74E;" FontSize="14" />
          <TextBlock Text="G-kod" />
        </StackPanel>
      </Button>
      <AppBarSeparator />
      <Button Command="{x:Bind ViewModel.UndoCommand}" ToolTipService.ToolTip="Poništi (Ctrl+Z)">
        <FontIcon Glyph="&#xE7A7;" FontSize="14" />
      </Button>
      <Button Command="{x:Bind ViewModel.RedoCommand}" ToolTipService.ToolTip="Ponovi (Ctrl+Y)">
        <FontIcon Glyph="&#xE7A6;" FontSize="14" />
      </Button>
    </StackPanel>

    <!-- ======== Gornji dio: Explorer | Canvas | Properties ======== -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="180" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" MinWidth="300" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="320" MinWidth="200" />
      </Grid.ColumnDefinitions>

      <!-- Project Explorer (sadržaj dolazi u M3) -->
      <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0" Margin="12,10,12,10"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="VALIDACIJA" />
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Issues, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedIssue, Mode=TwoWay}"
            SelectionMode="Single">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="MinHeight" Value="0" />
              <Setter Property="Padding" Value="12,4,12,4" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="vm:IssueDisplay">
              <StackPanel>
                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{x:Bind Header}" />
                <TextBlock FontSize="11" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind Message}" />
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>

      <toolkit:GridSplitter Grid.Column="1" Width="6" />

      <!-- Canvas: SkiaSharp viewport (M4) -->
      <Grid Grid.Column="2" Background="#FF1E1E1E">
        <skia:SKXamlCanvas
            x:Name="Canvas"
            PaintSurface="OnPaintSurface"
            PointerWheelChanged="OnCanvasWheel"
            PointerPressed="OnCanvasPointerPressed"
            PointerMoved="OnCanvasPointerMoved"
            PointerReleased="OnCanvasPointerReleased"
            SizeChanged="OnCanvasSizeChanged" />
        <StackPanel
            Orientation="Horizontal" Spacing="4"
            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
          <Button Content="Extents" FontSize="12" Padding="8,2"
                  Command="{x:Bind ViewModel.Viewport.ZoomExtentsCommand}"
                  ToolTipService.ToolTip="Zoom Extents" />
          <Button Content="Selected" FontSize="12" Padding="8,2"
                  Command="{x:Bind ViewModel.Viewport.ZoomSelectedCommand}"
                  ToolTipService.ToolTip="Zoom Selected" />
        </StackPanel>

        <!-- Transport simulacije -->
        <Grid
            HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
            Padding="10,6,10,6"
            Background="#CC252526"
            Visibility="{x:Bind ViewModel.Simulation.HasProgram, Mode=OneWay}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Padding="10,2" Margin="0,0,4,0"
                  Command="{x:Bind ViewModel.Simulation.TogglePlayCommand}">
            <FontIcon Glyph="&#xE768;" FontSize="13" />
          </Button>
          <Button Grid.Column="1" Padding="10,2" Margin="0,0,8,0"
                  Command="{x:Bind ViewModel.Simulation.StopCommand}">
            <FontIcon Glyph="&#xE71A;" FontSize="13" />
          </Button>
          <Slider Grid.Column="2" x:Name="SimSlider" Margin="0,0,8,0"
                  Minimum="0"
                  Maximum="{x:Bind ViewModel.Simulation.TotalDuration, Mode=OneWay}"
                  Value="{x:Bind ViewModel.Simulation.CurrentTime, Mode=TwoWay}"
                  StepFrequency="0.1" />
          <ComboBox Grid.Column="3" x:Name="SpeedBox" Margin="0,0,8,0"
                    SelectedIndex="1" SelectionChanged="OnSpeedChanged" FontSize="12">
            <ComboBoxItem Content="0.5×" />
            <ComboBoxItem Content="1×" />
            <ComboBoxItem Content="2×" />
            <ComboBoxItem Content="5×" />
            <ComboBoxItem Content="10×" />
          </ComboBox>
          <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="12"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     Text="{x:Bind ViewModel.Simulation.StatusText, Mode=OneWay}" />
        </Grid>
      </Grid>

      <toolkit:GridSplitter Grid.Column="3" Width="6" />

      <!-- Properties (sadržaj dolazi u M5) -->
      <Grid Grid.Column="4" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0" Margin="12,10,12,10"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="PROPERTIES" />
      </Grid>
    </Grid>

    <toolkit:GridSplitter Grid.Row="2" Height="6" />

    <!-- ======== Output Console ======== -->
    <Grid Grid.Row="3" Background="{ThemeResource LayerFillColorDefaultBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="12,6,12,6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.Column="0" VerticalAlignment="Center"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="OUTPUT CONSOLE" />
        <Button
            Grid.Column="1" Padding="8,2"
            Command="{x:Bind Console.ClearCommand}"
            Content="Očisti" FontSize="12" />
      </Grid>

      <ListView
          Grid.Row="1"
          ItemsSource="{x:Bind Console.Lines}"
          SelectionMode="None"
          IsItemClickEnabled="False">
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="12,1,12,1" />
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate x:DataType="vm:LogLine">
            <TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap">
              <Run Text="{x:Bind Timestamp}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
              <Run Text="{x:Bind Level}" />
              <Run Text="{x:Bind Text}" />
            </TextBlock>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>

    <!-- ======== Status traka ======== -->
    <Grid Grid.Row="4" Background="{ThemeResource AccentFillColorDefaultBrush}">
      <TextBlock
          Margin="12,3,12,3" FontSize="12"
          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
          Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
    </Grid>
  </Grid>
</Window>
